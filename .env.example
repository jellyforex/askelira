# =============================================================
# AskElira 2.1 — Environment Configuration
# =============================================================
# Copy to .env and fill in your values.
# Run 'askelira init' to generate your personal USER.md workspace file.
# =============================================================

# ── Anthropic ────────────────────────────────────────────────
# Claude API key for all agent reasoning
ANTHROPIC_API_KEY=sk-ant-...

# ── Search Providers ─────────────────────────────────────────
# Toggle with SEARCH_PROVIDER: auto | tavily | brave | perplexity
SEARCH_PROVIDER=auto
TAVILY_API_KEY=tvly-...
BRAVE_SEARCH_API_KEY=BSA...
PERPLEXITY_API_KEY=pplx-...

# ── OpenClaw Gateway ─────────────────────────────────────────
# WebSocket gateway for inter-agent communication
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=

# ── Agent Routing ────────────────────────────────────────────
# gateway = prefer gateway, fallback to direct API (default)
# direct = always use Anthropic API directly
# gateway-only = fail if gateway is down
AGENT_ROUTING_MODE=gateway

# ── Channels ─────────────────────────────────────────────────
# Telegram delivery
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Database ─────────────────────────────────────────────────
POSTGRES_URL=postgresql://...
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# ── Stripe (optional for dev) ────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Admin ────────────────────────────────────────────────────
ADMIN_EMAIL=

# ── Cron ─────────────────────────────────────────────────────
CRON_SECRET=generate-random-hex

# ── Optional ─────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
WORKSPACES_PATH=~/askelira/workspaces
